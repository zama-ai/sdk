# Optional: override the default testnet relayer URL (https://relayer.testnet.zama.org/v2)
# Must include the versioned path prefix /v2 — the proxy appends endpoint names directly
# (e.g. /keyurl, /submit). Without /v2, those requests 404 on the relayer.
# RELAYER_URL=https://relayer.testnet.zama.org/v2

# Optional: API key — required for mainnet, not needed for testnet
# RELAYER_API_KEY=your-api-key

# Optional: override the default Sepolia RPC URL (https://ethereum-sepolia-rpc.publicnode.com)
# Use || not ?? — Next.js replaces unset NEXT_PUBLIC_* with "" at build time, not undefined.
# NEXT_PUBLIC_SEPOLIA_RPC_URL=
