direction: down

title: {
  label: "@zama-fhe/react-sdk Module Map"
  near: top-center
  shape: text
  style.font-size: 24
  style.bold: true
}

# --- React SDK ---
react-sdk: "@zama-fhe/react-sdk" {
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
  style.font-size: 14

  provider: "ZamaProvider\n→ ZamaContext" {
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }

  query-hooks: "Query Hooks\nuseConfidentialBalance · useMetadata\nuseTotalSupply · useIsConfidential · useActivityFeed" {
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }

  mutation-hooks: "Mutation Hooks\nuseShield · useConfidentialTransfer\nuseUnshield · useAllow · useRevoke" {
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }

  wagmi: "Signer Sub-path\n/wagmi → WagmiSigner" {
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }
}

# --- Core SDK ---
query-factories: "@zama-fhe/sdk/query\nqueryOptions · mutationOptions" {
  style.fill: "#E0F7FA"
  style.stroke: "#00838F"
  style.font-size: 14
}

sdk: "@zama-fhe/sdk\nZamaSDK · Token · ReadonlyToken" {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.font-size: 14
}

# --- Connections ---
react-sdk.provider -> sdk: "initializes"
react-sdk.query-hooks -> query-factories: "uses"
react-sdk.mutation-hooks -> query-factories: "uses"
query-factories -> sdk: "calls"
react-sdk.wagmi -> sdk: "GenericSigner"
