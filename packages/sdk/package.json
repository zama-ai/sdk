{
  "name": "@zama-fhe/sdk",
  "version": "1.0.0-alpha.7",
  "description": "TypeScript SDK for Zama confidential ERC-20 tokens (fhEVM)",
  "license": "BSD-3-Clause-Clear",
  "author": "Zama",
  "repository": {
    "type": "git",
    "url": "https://github.com/zama-ai/sdk",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cleartext": {
      "types": "./dist/cleartext/index.d.ts",
      "import": "./dist/cleartext/index.js"
    },
    "./viem": {
      "types": "./dist/viem/index.d.ts",
      "import": "./dist/viem/index.js"
    },
    "./ethers": {
      "types": "./dist/ethers/index.d.ts",
      "import": "./dist/ethers/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    },
    "./cleartext": {
      "types": "./dist/cleartext/index.d.ts",
      "import": "./dist/cleartext/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "fhe",
    "zama",
    "fhevm",
    "confidential",
    "erc20",
    "privacy",
    "homomorphic-encryption",
    "token",
    "ethereum",
    "blockchain"
  ],
  "homepage": "https://github.com/zama-ai/sdk#readme",
  "bugs": {
    "url": "https://github.com/zama-ai/sdk/issues"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@zama-fhe/relayer-sdk": "0.4.1",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "viem": ">=2",
    "ethers": ">=6",
    "@zama-fhe/relayer-sdk": "~0.4.1"
  },
  "sideEffects": false,
  "peerDependenciesMeta": {
    "viem": {
      "optional": true
    },
    "ethers": {
      "optional": true
    },
    "@zama-fhe/relayer-sdk": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  }
}
