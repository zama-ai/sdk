{
  "name": "@zama-fhe/react-native-sdk",
  "version": "3.0.0-alpha.7",
  "description": "React Native SDK for Zama confidential token operations",
  "license": "BSD-3-Clause-Clear",
  "author": "Zama",
  "repository": {
    "type": "git",
    "url": "https://github.com/zama-ai/sdk",
    "directory": "packages/react-native-sdk"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./polyfills": {
      "types": "./dist/polyfills.d.ts",
      "import": "./dist/polyfills.js",
      "default": "./dist/polyfills.js"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "fhe",
    "zama",
    "fhevm",
    "confidential",
    "erc20",
    "privacy",
    "homomorphic-encryption",
    "react-native",
    "expo",
    "hooks",
    "ethereum"
  ],
  "homepage": "https://github.com/zama-ai/sdk#readme",
  "bugs": {
    "url": "https://github.com/zama-ai/sdk/issues"
  },
  "scripts": {
    "build": "rm -rf dist && rolldown --config rolldown.config.ts",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fhevm/react-native-sdk": "file:./fhevm-react-native-sdk-0.1.0.tgz"
  },
  "devDependencies": {
    "@zama-fhe/sdk": "workspace:*",
    "@zama-fhe/react-sdk": "workspace:*",
    "expo-sqlite": "~16.0.0",
    "rolldown": "1.0.0-rc.7",
    "rolldown-plugin-dts": "^0.23.2"
  },
  "peerDependencies": {
    "@zama-fhe/sdk": "^3.0.0-alpha.7",
    "@zama-fhe/react-sdk": "^3.0.0-alpha.7",
    "@tanstack/react-query": ">=5",
    "react": ">=18.0.0",
    "expo": ">=52.0.0",
    "react-native": ">=0.76.0",
    "expo-sqlite": ">=15.0.0",
    "react-native-quick-crypto": ">=0.7.0"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  }
}
