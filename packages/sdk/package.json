{
  "name": "@zama-fhe/sdk",
  "version": "2.2.0",
  "description": "TypeScript SDK for Zama fhEVM confidential smart contracts",
  "license": "BSD-3-Clause-Clear",
  "author": "Zama",
  "repository": {
    "type": "git",
    "url": "https://github.com/zama-ai/sdk",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      },
      "default": "./dist/esm/index.js"
    },
    "./cleartext": {
      "import": {
        "types": "./dist/esm/cleartext/index.d.ts",
        "default": "./dist/esm/cleartext/index.js"
      },
      "require": {
        "types": "./dist/esm/cleartext/index.d.ts",
        "default": "./dist/cjs/cleartext/index.cjs"
      },
      "default": "./dist/esm/cleartext/index.js"
    },
    "./query": {
      "import": {
        "types": "./dist/esm/query/index.d.ts",
        "default": "./dist/esm/query/index.js"
      },
      "require": {
        "types": "./dist/esm/query/index.d.ts",
        "default": "./dist/cjs/query/index.cjs"
      },
      "default": "./dist/esm/query/index.js"
    },
    "./viem": {
      "import": {
        "types": "./dist/esm/viem/index.d.ts",
        "default": "./dist/esm/viem/index.js"
      },
      "require": {
        "types": "./dist/esm/viem/index.d.ts",
        "default": "./dist/cjs/viem/index.cjs"
      },
      "default": "./dist/esm/viem/index.js"
    },
    "./ethers": {
      "import": {
        "types": "./dist/esm/ethers/index.d.ts",
        "default": "./dist/esm/ethers/index.js"
      },
      "require": {
        "types": "./dist/esm/ethers/index.d.ts",
        "default": "./dist/cjs/ethers/index.cjs"
      },
      "default": "./dist/esm/ethers/index.js"
    },
    "./node": {
      "import": {
        "types": "./dist/esm/node/index.d.ts",
        "default": "./dist/esm/node/index.js"
      },
      "default": "./dist/esm/node/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "cleartext": [
        "./dist/esm/cleartext/index.d.ts"
      ],
      "query": [
        "./dist/esm/query/index.d.ts"
      ],
      "viem": [
        "./dist/esm/viem/index.d.ts"
      ],
      "ethers": [
        "./dist/esm/ethers/index.d.ts"
      ],
      "node": [
        "./dist/esm/node/index.d.ts"
      ]
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.cjs",
    "dist/**/*.d.ts",
    "dist/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "fhe",
    "zama",
    "fhevm",
    "confidential",
    "erc20",
    "privacy",
    "homomorphic-encryption",
    "token",
    "ethereum",
    "blockchain"
  ],
  "homepage": "https://github.com/zama-ai/sdk#readme",
  "bugs": {
    "url": "https://github.com/zama-ai/sdk/issues"
  },
  "scripts": {
    "build": "rm -rf dist && rolldown --config rolldown.config.ts",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@zama-fhe/relayer-sdk": "~0.4.2",
    "viem": "^2.47.6"
  },
  "devDependencies": {
    "@tanstack/query-core": "^5.95.2",
    "rolldown": "1.0.0-rc.7",
    "rolldown-plugin-dts": "^0.23.2"
  },
  "peerDependencies": {
    "@tanstack/query-core": ">=5",
    "ethers": ">=6",
    "viem": ">=2"
  },
  "sideEffects": false,
  "peerDependenciesMeta": {
    "@tanstack/query-core": {
      "optional": true
    },
    "viem": {
      "optional": true
    },
    "ethers": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
