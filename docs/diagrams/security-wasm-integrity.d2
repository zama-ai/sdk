direction: right

title: {
  label: "WASM Bundle Loading"
  near: top-center
  shape: text
  style.font-size: 24
  style.bold: true
}

# --- Flow ---
npm: "node_modules\n@zama-fhe/relayer-sdk" {
  shape: package
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.font-size: 14
}

build: "Build\n(rolldown plugin)" {
  style.fill: "#F3E5F5"
  style.stroke: "#6A1B9A"
  style.font-size: 14
}

dist: "dist/esm/\nrelayer-sdk-js.umd.cjs" {
  shape: page
  style.fill: "#FFFDE7"
  style.stroke: "#F57F17"
  style.font-size: 14
}

worker: "Web Worker\nimportScripts()" {
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  style.font-size: 14
}

wasm: "Execute WASM\n(FHE operations)" {
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
  style.font-size: 14
  style.bold: true
}

# --- Connections ---
npm -> build: "read UMD at\nbuild time"
build -> dist: "emit asset"
dist -> worker: "importScripts\n(same origin)"
worker -> wasm: "initSDK()"
