{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "target": "es2022",
    "paths": {
      "@zama-fhe/sdk": ["./packages/sdk/src"],
      "@zama-fhe/sdk/*": ["./packages/sdk/src/*"],
      "@zama-fhe/token-react-sdk": ["./packages/token-react-sdk/src"],
      "@zama-fhe/token-react-sdk/*": ["./packages/token-react-sdk/src/*"]
    }
  },
  "include": ["packages/**/*.ts", "packages/**/*.tsx"],
  "exclude": ["node_modules", "**/node_modules", "packages/test-app"]
}
