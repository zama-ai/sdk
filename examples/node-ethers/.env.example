# Account A — main account (shield, transfer, unshield, delegate)
PRIVATE_KEY=0x...

# Account B — delegate account (used in Section 4: delegation)
DELEGATE_PRIVATE_KEY=0x...

# Sepolia RPC endpoint (Infura, Alchemy, or any public node)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# Relayer API key — required on Mainnet, optional on Sepolia testnet
# RELAYER_API_KEY=your-api-key
