# ── Required ─────────────────────────────────────────────────────────────────
# Private key of the EOA used as the reference signer.
# Must have Sepolia ETH for the transaction test (get some at sepoliafaucet.com).
PRIVATE_KEY=0x...

# ── Optional — Network ────────────────────────────────────────────────────────
# Sepolia JSON-RPC endpoint. Defaults to the public publicnode endpoint.
# Override with a private endpoint (Infura, Alchemy) if needed.
# RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ── Optional — Relayer ────────────────────────────────────────────────────────
# Zama relayer base URL. Defaults to the public Sepolia testnet relayer.
# Override for a private relayer (staging, mainnet).
# RELAYER_URL=https://relayer.testnet.zama.org/v2

# API key forwarded as x-api-key. Not required for Sepolia testnet.
# Required when pointing RELAYER_URL at a mainnet or private relayer.
# RELAYER_API_KEY=
