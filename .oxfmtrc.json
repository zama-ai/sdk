{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "sortPackageJson": false,
  "ignorePatterns": [
    "dist",
    "node_modules",
    "pnpm-lock.yaml",
    "coverage",
    "*.tsbuildinfo",
    "hardhat",
    "docs/gitbook/build",
    "packages/sdk/etc",
    "packages/react-sdk/etc",
    "contracts/lib"
  ]
}
