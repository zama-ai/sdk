{
  "name": "@zama-fhe/sdk-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for Zama SDK packages",
  "license": "BSD-3-Clause-Clear",
  "repository": {
    "type": "git",
    "url": "https://github.com/zama-ai/sdk"
  },
  "author": "Zama",
  "scripts": {
    "build": "pnpm build:sdk && pnpm build:react-sdk",
    "build:sdk": "pnpm --filter @zama-fhe/sdk build",
    "build:react-sdk": "pnpm --filter @zama-fhe/react-sdk build",
    "build:test-nextjs": "pnpm --filter @zama-fhe/test-nextjs build",
    "build:test-vite": "pnpm --filter @zama-fhe/test-vite  build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:integration": "vitest run --reporter=verbose --config vitest.integration.config.ts",
    "typecheck": "pnpm run --parallel --recursive '/^typecheck/'",
    "lint": "oxlint && pnpm ast-grep:scan",
    "ast-grep:scan": "ast-grep scan --config sgconfig.yml",
    "lint:fix": "oxlint --fix --fix-suggestions",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "release:ci": "pnpm exec semantic-release",
    "release:dry-run": "pnpm exec semantic-release --dry-run --no-ci --debug",
    "postinstall": "test -n \"$CI\" || (git submodule update --init --recursive && pnpm forge-fhevm:install && pnpm contracts:install)",
    "forge-fhevm:install": "cd contracts/lib/forge-fhevm && GIT_LFS_SKIP_SMUDGE=1 forge soldeer install",
    "contracts:install": "cd contracts && GIT_LFS_SKIP_SMUDGE=1 forge soldeer install",
    "prepare": "husky",
    "submodule:update": "git submodule update --remote --merge",
    "contracts:build": "cd contracts && forge build",
    "anvil": "anvil --port 8545 --chain-id 31337 --silent",
    "e2e:test": "pnpm --filter @zama-fhe/playwright e2e:test",
    "e2e:test:ui": "pnpm --filter @zama-fhe/playwright e2e:test:ui",
    "e2e:test:nextjs": "pnpm --filter @zama-fhe/playwright e2e:test:nextjs",
    "e2e:test:vite": "pnpm --filter @zama-fhe/playwright e2e:test:vite",
    "e2e:test:node": "pnpm build:sdk && pnpm --filter @zama-fhe/playwright e2e:test:node",
    "docs:diagrams": "node scripts/docs/generate-diagrams.mjs",
    "docs:preview": "mdbook serve docs/gitbook --open",
    "docs:build": "mdbook build docs/gitbook",
    "typedoc": "typedoc",
    "api-report": "pnpm build && pnpm api-report:sdk && pnpm api-report:react-sdk",
    "api-report:sdk": "cd packages/sdk && api-extractor run --local -c api-extractor.json && api-extractor run --local -c api-extractor.viem.json && api-extractor run --local -c api-extractor.ethers.json && api-extractor run --local -c api-extractor.node.json && api-extractor run --local -c api-extractor.query.json",
    "api-report:react-sdk": "cd packages/react-sdk && api-extractor run --local -c api-extractor.json && api-extractor run --local -c api-extractor.wagmi.json",
    "api-report:check": "pnpm build && pnpm api-report:check:sdk && pnpm api-report:check:react-sdk",
    "api-report:check:sdk": "cd packages/sdk && api-extractor run -c api-extractor.json && api-extractor run -c api-extractor.viem.json && api-extractor run -c api-extractor.ethers.json && api-extractor run -c api-extractor.node.json && api-extractor run -c api-extractor.query.json",
    "api-report:check:react-sdk": "cd packages/react-sdk && api-extractor run -c api-extractor.json && api-extractor run -c api-extractor.wagmi.json",
    "setup:claude": "bash scripts/setup-claude.sh",
    "size": "size-limit",
    "size:json": "size-limit --json"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.42.0",
    "@faker-js/faker": "^10.4.0",
    "@fhevm/mock-utils": "0.4.2",
    "@microsoft/api-extractor": "^7.57.7",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@size-limit/file": "^12.0.1",
    "@tanstack/react-query": "^5.95.2",
    "@terrastruct/d2": "^0.1.33",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.15",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "@zama-fhe/relayer-sdk": "0.4.2",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "ethers": "^6.16.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mdbook": "workspace:*",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "0.18.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rolldown": "1.0.0-rc.9",
    "rolldown-plugin-dts": "^0.22.5",
    "semantic-release": "^25.0.3",
    "size-limit": "^12.0.1",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.2",
    "typescript-language-server": "^5.1.3",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "oxlint --fix",
      "ast-grep scan --config sgconfig.yml"
    ],
    "*.{ts,tsx,js,mjs,cjs,json,yaml,yml}": "oxfmt"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@ast-grep/cli"
    ],
    "overrides": {
      "minimatch": "10.2.4",
      "@walletconnect/ethereum-provider": "^2.23.7",
      "lodash": ">=4.18.0",
      "lodash-es": ">=4.18.0"
    }
  },
  "overrides": {
    "minimatch": "10.2.4"
  },
  "workspaces": [
    "packages/*",
    "tools/*"
  ],
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  }
}
