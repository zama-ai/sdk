# Relayer — server-side (not exposed to the browser)
# Defaults to the public Sepolia testnet relayer when unset — no API key required for testnet.
# RELAYER_URL=https://relayer.testnet.zama.org/v2
# RELAYER_API_KEY=your_api_key_here

# Optional: override the default Sepolia RPC (https://ethereum-sepolia-rpc.publicnode.com)
# NEXT_PUBLIC_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
